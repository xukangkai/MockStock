# ═══════════════════════════════════════════════════
#  A股模拟短线交易训练器 - 配置文件
# ═══════════════════════════════════════════════════
#  复制本文件为 .env 并填入你的配置：
#    cp .env.example .env
# ═══════════════════════════════════════════════════

# ── AI 模型配置（必填）─────────────────────────────
# 支持所有兼容 OpenAI 格式的 API（DeepSeek、阿里百炼、OpenAI 等）
DEEPSEEK_API_KEY=你的API密钥
DEEPSEEK_MODEL=deepseek-v4-pro
DEEPSEEK_BASE_URL=https://token-plan.cn-beijing.maas.aliyuncs.com/compatible-mode/v1

# ── 数据库配置 ─────────────────────────────────────
# 可选值: sqlite（默认） 或 mysql
DB_TYPE=sqlite

# 以下仅 DB_TYPE=mysql 时需要配置
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_USER=root
# DB_PASS=your_password
# DB_NAME=sim_trader

# ── Web 服务配置 ───────────────────────────────────
PORT=8080
